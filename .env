# Configuration Directories
CONFIG_DIR=./config
ASSETS_DIR=./assets
SECRETS_DIR=${CONFIG_DIR}/secrets/
NPM_DEPENDANT_DIRS=stitchery-frontend:stitchery-api

# TLS/SSL Settings
APP_DOMAIN=stitchery.localhost
SSL_EMAIL=connor@tevonial.com
CERTBOT_STAGING=false
RSA_KEY_SIZE=4096

# Hostnames & Ports
HOST_URI_SCHEME=https
HOST_URI=${HOST_URI_SCHEME}://${APP_DOMAIN}
API_ROUTE=api
API_PORT_GRAPHQL=3000
API_PORT_REST=3001
FRONTEND_PORT=8080

# Database
DB_CREDENTIALS_FILE=db-credentials
DB_CONNECTION_LIMIT=10
DB_URI_SCHEME=postgres
REDIS_HOST=redis://redis

# pgAdmin
PGADMIN_DEFAULT_EMAIL=connor@tevonial.com
PGADMIN_PASSWORD_FILE=pg-admin-password

# Apollo GraphQL
APOLLO_KEY=service:Stitchery:E52WFBxGV_qZU5UqNIFnuw
APOLLO_GRAPH_REF=Stitchery@current
APOLLO_SCHEMA_REPORTING=true

# Authentication & Cryptography
JWT_SECRET_FILE=jwt-secret
CONNECT_SECRET_FILE=connect-secret

# Frontend Environment
API_BASE_URI=${HOST_URI}/${API_ROUTE}
STATIC_BASE_URI=${HOST_URI}/static
STORAGE_KEY_JWT=jwt
CONNECT_CONFIG_DIR=/var/connect/
