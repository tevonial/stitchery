# Configuration Directories
CONFIG_DIR=./config/
SECRETS_DIR=${CONFIG_DIR}secrets/
NPM_DEPENDANT_DIRS=stitchery-frontend:stitchery-api

# Container Ports
API_PORT=3000
FRONTEND_PORT=8080

# TLS/SSL Settings
APP_DOMAIN=stitchery.localhost
SSL_EMAIL=
CERTBOT_STAGING=true
RSA_KEY_SIZE=4096

# Database
DB_CREDENTIALS_FILE=db-credentials
DB_CONNECTION_LIMIT=10
DB_URI_SCHEME=postgres

# pgAdmin
PGADMIN_DEFAULT_EMAIL=
PGADMIN_PASSWORD_FILE=

# Apollo GraphQL
APOLLO_KEY=
APOLLO_GRAPH_REF=
APOLLO_SCHEMA_REPORTING=

# Authentication
JWT_SECRET_FILE=jwt-secret