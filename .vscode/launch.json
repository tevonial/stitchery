{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "[api] debug",
            "presentation": {
                "group": "api",
                "order": 1
            },
            "type": "node",
            "request": "attach",
            "remoteRoot": "/app",
            "localRoot": "${workspaceFolder}/stitchery-api",
            "preLaunchTask": "[api] dev:debug",
            "autoAttachChildProcesses": true,
            "smartStep": true,
            "skipFiles": [
                "${workspaceFolder}/**/node_modules/**/*.js"
            ],
            "continueOnAttach": true
        },
        {
            "name": "[frontend] browser debug",
            "presentation": {
                "group": "frontend",
                "order": 1
            },
            "type": "editor-browser",
            "request": "launch",
            "preLaunchTask": "[frontend] dev:debug",
            "url": "https://stitchery.localhost",
            "webRoot": "${workspaceFolder}/stitchery-frontend/",
            "smartStep": true,
            // "skipFiles": [
            //     "${workspaceFolder}/**/node_modules/**/*.js"
            // ],
        },
        {
            "name": "[frontend] node attach",
            "presentation": {
                "group": "frontend",
                "order": 2
            },
            "env": {
                "ENV2TS_INSPECT": "true"
            },
            "type": "node",
            "request": "attach",
            "port": 9230,
            "remoteRoot": "/app",
            "localRoot": "${workspaceFolder}/stitchery-frontend",
            "preLaunchTask": "[frontend] dev",
            "autoAttachChildProcesses": false,
            "attachExistingChildren": false,
            "smartStep": true,
            "skipFiles": [
                "${workspaceFolder}/**/node_modules/**/*.js"
            ],
            "restart": true
        },
    ],
    "compounds": [
        {
            "name": "[fullstack] Debug",
            "configurations": [
                "[api] debug",
                "[frontend] browser debug"
            ],
            "preLaunchTask": "[nginx] reload"
        },
    ]
}
