{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "[api] debug",
            "presentation": {
                "group": "api",
                "order": 1
            },
            "type": "node",
            "request": "attach",
            "remoteRoot": "/app",
            "localRoot": "${workspaceFolder}/stitchery-api",
            "preLaunchTask": "[api] dev:debug",
            "autoAttachChildProcesses": true,
            "smartStep": true,
            "skipFiles": [
                "${workspaceFolder}/**/node_modules/**/*.js",
            ]
        },
        {
            "name": "[frontend] debug",
            "presentation": {
                "group": "frontend",
                "order": 1
            },
            "type": "msedge",
            "request": "launch",
            "url": "http://stitchery.localhost/",
            "webRoot": "${workspaceFolder}/stitchery-frontend/src",
            "smartStep": true,
            "skipFiles": [
                "${workspaceFolder}/**/node_modules/**/*.js"
            ]
        }
    ]
}